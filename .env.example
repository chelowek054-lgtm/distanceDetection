# Скопируйте в .env и поправьте значения.

# Корень приложения задаётся по расположению app/infrastructure/config.py.
# Относительные пути считаются от корня проекта (distanceDetection/).

# Директория для локальных весов (рекомендуется хранить .pt здесь).
MODELS_DIR=models

# Имя файла весов YOLOE внутри MODELS_DIR.
YOLOE_WEIGHTS_FILE=yoloe-26x-seg.pt

# Загрузки пользовательских файлов (видео, образцы промптов).
UPLOADS_DIR=uploads